# Kopiera till `.env` lokalt:  cp env.example .env

# Lokal dev mot docker-compose-databasen
DATABASE_URL=postgres://geo:geo@localhost:5432/geoaudio
PORT=4000
# Komma-separerad lista över origins som tillåts av CORS
CORS_ORIGINS=http://localhost:1234

# OpenAI – för audio:generate-scriptet
OPENAI_API_KEY=
# Modell: tts-1 (snabbare, billigare) eller tts-1-hd (högre kvalitet)
OPENAI_TTS_MODEL=tts-1
# Röst: alloy, echo, fable, onyx, nova, shimmer
OPENAI_TTS_VOICE=nova
# Var mp3:erna sparas. Default = web-appens public-mapp.
AUDIO_OUTPUT_DIR=../web/public/audio
