# ============================================
# Server-side (krävs i runtime)
# ============================================

# Postgres connection string.
# Lokalt: peka på din Docker-container.
# Prod: Supabase Transaction Pooler URL (port 6543).
DATABASE_URL=postgres://geo:geo@localhost:5432/geoaudio

# ============================================
# OpenAI – endast för audio:generate-scriptet
# ============================================
OPENAI_API_KEY=
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova

# ============================================
# Klient (NEXT_PUBLIC_ exponeras i browsern)
# ============================================

# Lämna tom för OpenFreeMap "positron". För egen kartstil:
# NEXT_PUBLIC_MAP_STYLE_URL=https://api.maptiler.com/maps/streets-v2/style.json?key=DIN_NYCKEL
NEXT_PUBLIC_MAP_STYLE_URL=
